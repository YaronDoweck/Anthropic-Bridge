[server]
host = "127.0.0.1"
port = 8000
log_level = "INFO"
debug_level = 0
output_dir = "logs"
# override_model = "claude-sonnet-4-6"

[endpoints]
anthropic_url = "https://api.anthropic.com"
#ollama_url = "http://127.0.0.1:11434"
ollama_url = "http://192.168.1.50:11434"
openai_url = "https://api.openai.com"

[models."claude-sonnet-4-6"]
endpoint = "anthropic"

[models."claude-opus-4-6"]
endpoint = "anthropic"

[models."claude-haiku-4-5"]
endpoint = "anthropic"

#[models."qwen3.5:9b"]
#endpoint = "ollama"
#claude_system_instructions = "passthrough"

#[models."gpt-4o"]
#endpoint = "openai"

[models."gemma4:26b"]
endpoint = "ollama"
claude_system_instructions = "passthrough"

[models."gpt-5-nano"]
endpoint = "openai"
