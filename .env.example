HOST=127.0.0.1
PORT=12345
LOG_LEVEL=INFO  # Set to DEBUG to print full request and response bodies

# Optional: proxy-level Anthropic credentials (used if client doesn't send auth headers)
# ANTHROPIC_AUTH_TOKEN=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key (required if any model uses endpoint = "openai")
# OPENAI_API_KEY=sk-...
